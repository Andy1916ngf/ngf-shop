# Copy to functions/.env and fill in all values.
# DO NOT commit .env to git — it is listed in .gitignore.
#
# Deploy to Firebase using:
#   firebase functions:config:set kustom.api_url="..." etc.

# ── Kustom Checkout ───────────────────────────────────────────
# Sandbox:    https://api.playground.kustom.co
# Production: https://api.kustom.co
KUSTOM_API_URL=https://api.playground.kustom.co
KUSTOM_API_KEY=REPLACE_ME_KUSTOM_API_KEY
KUSTOM_WEBHOOK_SECRET=REPLACE_ME_WEBHOOK_SECRET

# ── App ───────────────────────────────────────────────────────
SHOP_DOMAIN=https://butik.nynashamnsgf.se
FIREBASE_PROJECT_ID=REPLACE_ME_FIREBASE_PROJECT_ID

# ── Email ─────────────────────────────────────────────────────
# This address is both the sender and the new-order notification recipient.
# In Google Workspace Admin, create a group butik@nynashamnsgf.se
# and add all shop admin members to it.
SHOP_EMAIL=butik@nynashamnsgf.se

# ── Google Workspace Groups (for admin role management) ───────
# Create both groups in Google Workspace Admin Console → Groups
GOOGLE_GROUPS_SITE_ADMIN=shop-site-admins@nynashamnsgf.se
GOOGLE_GROUPS_SHOP_ADMIN=shop-admins@nynashamnsgf.se

# A Google Workspace admin email used to impersonate API calls.
# The Cloud Function service account must have domain-wide delegation
# with scope: https://www.googleapis.com/auth/admin.directory.group.member.readonly
GOOGLE_ADMIN_EMAIL=REPLACE_ME_WORKSPACE_ADMIN@nynashamnsgf.se
