rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────

    // Checks the ngfRole custom claim set by the getRole Cloud Function.
    // The claim lives in the JWT — no extra database read required.
    // No domain restriction — access is controlled by config/adminRoles.
    function isNgfAdmin() {
      return request.auth != null
        && request.auth.token.get('ngfRole', null) != null;
    }

    function isSiteAdmin() {
      return isNgfAdmin()
        && request.auth.token.ngfRole == 'siteAdmin';
    }

    // ── Products ──────────────────────────────────────────────
    match /products/{id} {
      allow read:  if resource.data.visible == true || isNgfAdmin();
      allow write: if false;
    }

    // ── Orders ────────────────────────────────────────────────
    match /orders/{id} {
      allow read:  if isNgfAdmin();
      allow write: if false;
    }

    match /orders/{id}/events/{eventId} {
      allow read:  if isNgfAdmin();
      allow write: if false;
    }

    // ── Coupons ───────────────────────────────────────────────
    // Admins can read and write; public has no access (prevents coupon discovery)
    match /coupons/{id} {
      allow read, write: if isNgfAdmin();
    }

    // ── Static page content ───────────────────────────────────
    match /content/{page} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Site config (hero, variants, maintenance, shipping) ───
    // Public read for hero/maintenance. Admin write via Cloud Functions.
    match /config/site {
      allow read:  if true;
      allow write: if false;
    }

    // ── Admin roles ───────────────────────────────────────────
    // Only admins can read; only siteAdmins can write.
    // Written directly by Settings page (no Cloud Function proxy needed).
    match /config/adminRoles {
      allow read:  if isNgfAdmin();
      allow write: if isSiteAdmin();
    }

    // ── Mail queue (Firebase Trigger Email extension) ─────────
    match /mail/{id} {
      allow read, write: if false;
    }
  }
}
